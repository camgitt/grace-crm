# ===========================================
# GRACE CRM Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# ------------------------------------------
# Supabase Configuration
# ------------------------------------------
# Get these from: https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ------------------------------------------
# Email Service (Resend)
# ------------------------------------------
# Get your API key from: https://resend.com/api-keys
# Note: This is used in the Supabase Edge Function, not in the frontend

RESEND_API_KEY=re_your_api_key_here

# ------------------------------------------
# Optional: API URL
# ------------------------------------------
# Only needed if you're running a custom backend instead of Supabase Edge Functions

VITE_API_URL=

# ------------------------------------------
# SMS Service (Twilio) - Optional
# ------------------------------------------
# Only needed if you want to send SMS messages
# Get credentials from: https://console.twilio.com/

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
