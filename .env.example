# GRACE CRM Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# FRONTEND ENVIRONMENT VARIABLES
# ===========================================
# These variables are prefixed with VITE_ and are safe for frontend use.
# They will be bundled into the client-side JavaScript.

# SECURITY SETTINGS
# Enable demo mode (NEVER set to true in production!)
# When Clerk is not configured, this allows automatic admin access
# VITE_ENABLE_DEMO_MODE=false

# SUPABASE (Database) - Required
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# CLERK (Authentication) - Required for Production
# Get these from: https://dashboard.clerk.com
# Required for user authentication and team management
# WARNING: Without Clerk, app will block access in production unless demo mode is enabled
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# STRIPE (Payments) - Publishable key only (safe for frontend)
# Get these from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Email display settings (non-sensitive)
VITE_EMAIL_FROM_ADDRESS=noreply@yourdomain.com
VITE_EMAIL_FROM_NAME=Grace Community Church

# ===========================================
# BACKEND ENVIRONMENT VARIABLES (SECRET KEYS)
# ===========================================
# These variables contain secrets and must ONLY be set on your backend server.
# They should NEVER be prefixed with VITE_ or exposed to the frontend.
#
# Set these in your server's environment (e.g., Vercel, Railway, Render, etc.)
# or in a separate .env file that is NOT loaded by Vite.

# STRIPE (Payments) - Secret key
# Required for creating charges, managing subscriptions, etc.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# RESEND (Email)
# Get from: https://resend.com/api-keys
# Required for sending emails (welcome, follow-up, reminders)
RESEND_API_KEY=re_xxx

# TWILIO (SMS)
# Get from: https://console.twilio.com
# Required for sending SMS messages (reminders, notifications)
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1234567890

# GOOGLE GEMINI (AI)
# Get from: https://ai.google.dev/
# Used for AI-powered features (personalized messages, summaries)
GEMINI_API_KEY=your-gemini-api-key

# SUPABASE (Server-side)
# The service role key has admin access - NEVER expose to frontend
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Server configuration
PORT=3001
FRONTEND_URL=http://localhost:5173

# ===========================================
# SECURITY CHECKLIST FOR PRODUCTION
# ===========================================
# 1. All STRIPE_SECRET_KEY, RESEND_API_KEY, TWILIO_AUTH_TOKEN must be on backend only
# 2. Configure Clerk authentication (disable demo mode)
# 3. Use HTTPS and proper security headers
# 4. Enable Row Level Security (RLS) on all Supabase tables
# 5. Rotate API keys regularly
# 6. Never commit .env files with real credentials to git
